{
  "logging_level": "DEBUG",
  "output_dir": ".turix_tmp",
  "brain_enable_thinking": false,
  "brain_llm": {
    "provider": "gpt",
    "model_name": "gpt-5.4",
    "api_key": "$OPENAI_API_KEY",
    "base_url": "https://api.openai.com/v1"
  },
  "actor_llm": {
    "provider": "gpt",
    "model_name": "gpt-5.4",
    "api_key": "$OPENAI_API_KEY",
    "base_url": "https://api.openai.com/v1"
  },
  "planner_llm": {
    "provider": "gpt",
    "model_name": "gpt-5.4",
    "api_key": "$OPENAI_API_KEY",
    "base_url": "https://api.openai.com/v1"
  },
  "memory_llm": {
    "provider": "gpt",
    "model_name": "gpt-5.4",
    "api_key": "$OPENAI_API_KEY",
    "base_url": "https://api.openai.com/v1"
  },
  "agent": {
    "task": "Open GitHub in a browser, search for TuriX-CUA, open the repository page, and stop when it is visible.",
    "memory_budget": 2000,
    "summary_memory_budget": 8000,
    "use_ui": false,
    "use_search": false,
    "use_skills": true,
    "skills_dir": "skills",
    "skills_max_chars": 4000,
    "use_plan": true,
    "max_actions_per_step": 5,
    "max_steps": 100,
    "force_stop_hotkey": "command+shift+2",
    "use_turix": true,
    "resume": false,
    "agent_id": null,
    "save_brain_conversation_path": "brain_llm_interactions.log",
    "save_actor_conversation_path": "actor_llm_interactions.log",
    "save_planner_conversation_path": "planner_llm_interactions.log",
    "save_actor_conversation_path_encoding": "utf-8",
    "save_brain_conversation_path_encoding": "utf-8",
    "save_planner_conversation_path_encoding": "utf-8"
  }
}
